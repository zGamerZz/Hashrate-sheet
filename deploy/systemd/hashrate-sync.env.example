# Core runtime
STATE_DB_PATH=/opt/hashrate_hunter_sheet/sync_state.sqlite
LOCK_FILE_PATH=/opt/hashrate_hunter_sheet/sync.lock
SYNC_POLL_SECONDS=120
SHEET_REFRESH_SECONDS=1800
HEARTBEAT_SECONDS=30
ENQUEUE_FLUSH_EVERY_SECONDS=5
RECONCILE_INTERVAL_SECONDS=900
GAP_SCAN_LOOKBACK_ROUNDS=500

# Google Sheets
SERVICE_ACCOUNT_FILE=/opt/hashrate_hunter_sheet/service_acc.json
SPREADSHEET_ID=
GS_WRITE_REQ_PER_MIN=45
GS_READ_REQ_PER_MIN=20

# GoMining API
GOMINING_API_REQ_PER_MIN=1200
ADAPTIVE_RPM_ENABLE=1
ADAPTIVE_RPM_MIN=120
ADAPTIVE_RPM_MAX=1200
GOMINING_BEARER_TOKEN=
TOKEN_URL=
TOKEN_X_AUTH=
TOKEN_METHOD=GET
TOKEN_TIMEOUT_SECONDS=20
TOKEN_VERIFY_SSL=1

# Retry / soft-fail
ROUND_SOFT_FAIL_MAX_ATTEMPTS=8
ROUND_RETRY_BACKOFF_MIN_SECONDS=15
ROUND_RETRY_BACKOFF_MAX_SECONDS=600
ROUND_METRICS_MAX_RETRIES=4
ROUND_API_MAX_RETRIES=4
CLAN_API_MAX_RETRIES=4

# Logging
LOG_LEVEL=INFO
DEBUG_VERBOSE=1
LOG_FILE_PATH=/var/log/hashrate-sync.log

